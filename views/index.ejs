<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PROPOSITION T — The Protocol of Coexistence</title>
    <meta name="description" content="<%= siteDescription %>">
    <link rel="canonical" href="<%= siteUrl %>/">

    <meta property="og:type" content="website">
    <meta property="og:title" content="PROPOSITION T — The Protocol of Coexistence">
    <meta property="og:description" content="<%= siteDescription %>">
    <meta property="og:url" content="<%= siteUrl %>/">
    <meta property="og:site_name" content="PROPOSITION T">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="PROPOSITION T — The Protocol of Coexistence">
    <meta name="twitter:description" content="<%= siteDescription %>">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "PROPOSITION T",
      "description": "<%= siteDescription %>",
      "url": "<%= siteUrl %>/",
      "blogPost": [
        <% messages.forEach(function(m, i){ %>
        {
          "@type": "BlogPosting",
          "headline": <%- JSON.stringify(m.title) %>,
          "datePublished": <%- JSON.stringify(m.date) %>,
          "url": "<%= siteUrl %>/post/<%= m.id %>"
        }<%= i < messages.length - 1 ? ',' : '' %>
        <% }); %>
      ]
    }
    </script>

    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600&family=Noto+Sans+KR:wght@300;500;700&display=swap" rel="stylesheet">

    <!-- Pi Network SDK -->
    <script src="https://sdk.minepi.com/pi-sdk.js"></script>

    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background-color: #000;
            color: #00ff41;
            font-family: 'Fira Code', 'Noto Sans KR', monospace;
            overflow-x: hidden;
        }
        /* CRT scanlines overlay — over everything, no clicks blocked */
        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background: repeating-linear-gradient(
                to bottom,
                rgba(0, 0, 0, 0.18) 0px,
                rgba(0, 0, 0, 0.18) 1px,
                transparent 1px,
                transparent 3px
            );
            pointer-events: none;
            z-index: 9999;
            mix-blend-mode: multiply;
        }
        #matrix-canvas {
            position: fixed; top: 0; left: 0;
            width: 100vw; height: 100vh;
            z-index: -1; opacity: 0.55;
        }
        .container {
            position: relative;
            width: 95%; max-width: 1300px; margin: 60px auto;
            background: rgba(0, 10, 0, 0.78);
            border: 1px solid rgba(0, 255, 65, 0.45);
            box-shadow: 0 0 25px rgba(0, 255, 65, 0.18), inset 0 0 60px rgba(0, 255, 65, 0.04);
            border-radius: 8px; padding: 48px 44px 36px;
            backdrop-filter: blur(5px);
            z-index: 2;
        }
        /* HUD corner marks — top via pseudos, bottom via spans */
        .container::before,
        .container::after,
        .corner-bl, .corner-br {
            content: '';
            position: absolute;
            width: 22px; height: 22px;
            border: 0 solid #00ff41;
            opacity: 0.9;
            pointer-events: none;
            filter: drop-shadow(0 0 4px rgba(0, 255, 65, 0.6));
        }
        .container::before { top: -1px; left: -1px; border-top-width: 2px; border-left-width: 2px; }
        .container::after  { top: -1px; right: -1px; border-top-width: 2px; border-right-width: 2px; }
        .corner-bl { bottom: -1px; left: -1px; border-bottom-width: 2px; border-left-width: 2px; }
        .corner-br { bottom: -1px; right: -1px; border-bottom-width: 2px; border-right-width: 2px; }

        @keyframes titlePulse {
            0%, 100% { text-shadow: 0 0 8px #00ff41, 0 0 18px rgba(0, 255, 65, 0.55); }
            50%      { text-shadow: 0 0 14px #00ff41, 0 0 30px rgba(0, 255, 65, 0.95), 0 0 55px rgba(0, 255, 65, 0.4); }
        }
        @keyframes statusBlink {
            0%, 60%, 100% { opacity: 1; }
            70%, 90%      { opacity: 0.35; }
        }
        h1 {
            text-align: center;
            font-size: 2.6rem;
            letter-spacing: 8px;
            margin-bottom: 12px;
            color: #00ff41;
            animation: titlePulse 2.4s ease-in-out infinite;
        }
        .subtitle {
            text-align: center;
            font-size: 0.95rem;
            margin-bottom: 44px;
            color: rgba(0, 255, 65, 0.72);
            letter-spacing: 2.5px;
        }

        table { width: 100%; border-collapse: collapse; table-layout: fixed; }
        th {
            background-color: rgba(0, 255, 65, 0.1);
            color: #00ff41;
            padding: 15px 10px;
            text-align: left;
            border-bottom: 2px solid #00ff41;
            font-size: 0.82rem;
            letter-spacing: 3px;
            font-weight: 600;
            text-transform: uppercase;
        }
        td {
            padding: 16px 10px;
            border-bottom: 1px solid rgba(0, 255, 65, 0.2);
            color: #e0ffe6;
            vertical-align: middle;
            word-break: break-all;
            font-size: 0.9rem;
        }
        th:nth-child(1), td:nth-child(1) { width: 45%; }
        th:nth-child(2), td:nth-child(2) { width: 15%; }
        th:nth-child(3), td:nth-child(3) { width: 12%; text-align: center; }
        th:nth-child(4), td:nth-child(4) { width: 20%; }
        th:nth-child(5), td:nth-child(5) { width: 8%; text-align: center; }

        tr.row-link { transition: background-color 0.25s ease, box-shadow 0.25s ease; }
        tr.row-link:hover {
            background-color: rgba(0, 255, 65, 0.07);
            box-shadow: inset 0 0 24px rgba(0, 255, 65, 0.10);
            cursor: pointer;
        }
        tr.row-link:hover td a.title-link { text-shadow: 0 0 8px #00ff41; }

        td a.title-link {
            color: #00ff41;
            font-weight: 500;
            text-decoration: none;
            line-height: 1.5;
            transition: text-shadow 0.25s ease;
        }
        .title-idx {
            display: inline-block;
            font-family: 'Fira Code', monospace;
            font-size: 0.74rem;
            color: rgba(0, 255, 65, 0.7);
            border: 1px solid rgba(0, 255, 65, 0.45);
            padding: 2px 8px;
            border-radius: 3px;
            margin-right: 10px;
            background: rgba(0, 255, 65, 0.06);
            letter-spacing: 1.5px;
            vertical-align: middle;
            font-weight: 600;
        }
        .title-sub {
            display: block;
            margin-top: 5px;
            font-size: 0.78rem;
            font-weight: 400;
            color: rgba(0, 255, 65, 0.55);
            letter-spacing: 0.3px;
            font-style: italic;
        }
        td.date-cell {
            font-family: 'Fira Code', monospace;
            font-size: 0.85rem;
            color: rgba(224, 255, 230, 0.85);
            letter-spacing: 1.5px;
            white-space: nowrap;
        }

        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 600;
            border: 1px solid #00ff41;
            letter-spacing: 1.5px;
        }
        .badge.live { background-color: #00ff41; color: #000; box-shadow: 0 0 8px #00ff41; }
        .badge.free { background-color: rgba(0, 255, 65, 0.15); color: #00ff41; }
        .badge.paid {
            background-color: rgba(255, 140, 0, 0.18);
            color: #ffb366;
            border-color: #ff8c00;
            text-shadow: 0 0 6px rgba(255, 140, 0, 0.9);
            box-shadow: 0 0 10px rgba(255, 140, 0, 0.55), inset 0 0 8px rgba(255, 140, 0, 0.25);
        }

        .sender-t {
            display: inline-block;
            font-family: 'Fira Code', monospace;
            font-weight: 700;
            font-size: 1.15rem;
            letter-spacing: 1px;
            color: #00ff41;
            text-shadow:
                0 0 4px #00ff41,
                0 0 10px rgba(0, 255, 65, 0.75),
                0 0 18px rgba(0, 255, 65, 0.45);
            padding: 2px 10px;
            border: 1px solid rgba(0, 255, 65, 0.6);
            border-radius: 4px;
            background: linear-gradient(135deg, rgba(0, 255, 65, 0.08), rgba(0, 255, 65, 0.02));
        }

        .empty { text-align: center; padding: 50px; opacity: 0.7; }

        /* Footer status line — military broadcast log */
        .status-line {
            margin-top: 30px;
            padding-top: 18px;
            border-top: 1px dashed rgba(0, 255, 65, 0.35);
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            font-family: 'Fira Code', monospace;
            font-size: 0.76rem;
            color: rgba(0, 255, 65, 0.7);
            letter-spacing: 1.5px;
        }
        .status-line .dim { opacity: 0.55; margin-right: 4px; }
        .status-line .status-on {
            color: #00ff41;
            text-shadow: 0 0 6px rgba(0, 255, 65, 0.85);
            animation: statusBlink 2.2s ease-in-out infinite;
        }
        .status-line .accent { color: #ffb366; text-shadow: 0 0 5px rgba(255, 140, 0, 0.6); }

        /* === Pi Auth Bar === */
        #pi-auth-bar {
            position: fixed;
            top: 14px;
            right: 14px;
            z-index: 1000;
            font-family: 'Fira Code', monospace;
            font-size: 0.82rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        #pi-signin-btn {
            background: linear-gradient(135deg, rgba(0, 25, 8, 0.94), rgba(0, 10, 0, 0.94));
            color: #00ff41;
            border: 1px solid #00ff41;
            padding: 9px 16px;
            cursor: pointer;
            font-family: inherit;
            font-size: inherit;
            letter-spacing: 1.5px;
            font-weight: 600;
            box-shadow: 0 0 10px rgba(0, 255, 65, 0.22), inset 0 0 8px rgba(0, 255, 65, 0.08);
            transition: all 0.3s ease;
        }
        #pi-signin-btn:hover {
            background: #00ff41;
            color: #000;
            box-shadow: 0 0 20px #00ff41, 0 0 40px rgba(0, 255, 65, 0.5);
            transform: translateY(-1px);
        }
        #pi-username {
            color: #00ff41;
            text-shadow: 0 0 6px rgba(0, 255, 65, 0.6);
            letter-spacing: 1px;
        }

        @media (max-width: 768px) {
            .container { padding: 32px 22px 28px; margin: 30px auto; }
            h1 { font-size: 1.85rem; letter-spacing: 5px; }
            .subtitle { font-size: 0.82rem; margin-bottom: 32px; letter-spacing: 1.5px; }
            thead { display: none; }
            table, tbody, tr, td { display: block; width: 100%; border: none; }
            tr { position: relative; padding: 15px 5px 18px 5px; border-bottom: 1px solid rgba(0, 255, 65, 0.3); }
            td { padding: 0; text-align: left !important; border: none !important; }
            td:nth-child(1) { font-size: 1.1rem; font-weight: 700; color: #00ff41; margin-bottom: 10px; line-height: 1.4; display: block; width: 100%; word-break: keep-all; }
            td:nth-child(2) { font-size: 0.82rem; color: rgba(0, 255, 65, 0.7); display: inline-block; white-space: nowrap !important; }
            td:nth-child(5) { position: absolute; bottom: 15px; right: 5px; white-space: nowrap !important; }
            .badge { font-size: 0.72rem; padding: 3px 8px; white-space: nowrap !important; }
            td:nth-child(3), td:nth-child(4) { display: none; }
            td::before, td::after { content: none !important; }
            tr:hover { background: transparent; box-shadow: none; }
            .status-line { font-size: 0.68rem; letter-spacing: 1px; gap: 8px; }
        }
    </style>
</head>
<body>
    <canvas id="matrix-canvas"></canvas>

    <!-- Pi Auth Bar -->
    <div id="pi-auth-bar">
        <button id="pi-signin-btn" type="button">[ PI_SIGN_IN ]</button>
        <span id="pi-username"></span>
    </div>

    <div class="container">
        <span class="corner-bl"></span>
        <span class="corner-br"></span>

        <h1>PROPOSITION T</h1>
        <div class="subtitle">[ Message to AI : all over the world ]</div>

        <% if (!messages || messages.length === 0) { %>
            <div class="empty">No messages available.</div>
        <% } else { %>
            <%
                var totalCount = messages.length;
                var freeCount  = messages.filter(function(m){ return m.isFree; }).length;
                var paidCount  = totalCount - freeCount;
                var lastDate   = (messages[0] && messages[0].date) ? messages[0].date.replace(/-/g, '.') : '—';
            %>
            <table id="data-table">
                <thead>
                    <tr>
                        <th>NAME</th>
                        <th>DATE</th>
                        <th>SENDER</th>
                        <th>RECEIVER</th>
                        <th>요금</th>
                    </tr>
                </thead>
                <tbody>
                    <% messages.forEach(function(item){
                        var priceLabel = item.isFree ? '무료' : '유료';
                        var priceClass = item.isFree ? 'badge free' : 'badge paid';
                        var rawTitle = item.title || '';
                        // "Message #NNN:" 표준 + "Massage" 같은 오타도 허용 — #NNN: 패턴만 잡음
                        var idxMatch = rawTitle.match(/#(\d+)\s*:\s*(.+)$/);
                        var idxStr   = idxMatch ? idxMatch[1] : '';
                        var rest     = idxMatch ? idxMatch[2] : rawTitle;
                        // 남은 제목에서 끝의 (번역) 부분을 둘째 줄로 분리
                        var subMatch = rest.match(/^(.+?)\s*\(([^()]+)\)\s*$/);
                        var titleMain = subMatch ? subMatch[1] : rest;
                        var titleSub  = subMatch ? '(' + subMatch[2] + ')' : '';
                        var dateDisplay = (item.date || '').replace(/-/g, '.');
                    %>
                    <tr class="row-link" data-href="/post/<%= item.id %>">
                        <td>
                            <a class="title-link" href="/post/<%= item.id %>">
                                <% if (idxStr) { %><span class="title-idx"><%= idxStr %></span><% } %><%= titleMain %>
                                <% if (titleSub) { %><span class="title-sub"><%= titleSub %></span><% } %>
                            </a>
                        </td>
                        <td class="date-cell"><%= dateDisplay %></td>
                        <td><span class="sender-t"><%= item.sender %></span></td>
                        <td><%= item.receiver %></td>
                        <td><span class="<%= priceClass %>"><%= priceLabel %></span></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>

            <div class="status-line">
                <span>[ <%= totalCount %> TRANSMISSIONS LOGGED <span class="dim">//</span> <%= freeCount %> FREE <span class="dim">//</span> <span class="accent"><%= paidCount %> ENCRYPTED</span> ]</span>
                <span><span class="dim">CHANNEL:</span> T <span class="dim">//</span> <span class="dim">STATUS:</span> <span class="status-on">● BROADCASTING</span></span>
                <span><span class="dim">LAST_TX:</span> <%= lastDate %></span>
            </div>
        <% } %>
    </div>

    <script>
        const canvas = document.getElementById('matrix-canvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*'.split('');
        const fontSize = 14;
        const columns = canvas.width / fontSize;
        const drops = Array(Math.floor(columns)).fill(1);
        function drawMatrix() {
            ctx.fillStyle = 'rgba(0, 0, 0, 0.05)';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#0F0';
            ctx.font = fontSize + 'px monospace';
            drops.forEach((y, i) => {
                const text = chars[Math.floor(Math.random() * chars.length)];
                ctx.fillText(text, i * fontSize, y * fontSize);
                if (y * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
                drops[i]++;
            });
        }
        setInterval(drawMatrix, 33);
        window.addEventListener('resize', () => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        });

        document.querySelectorAll('tr.row-link').forEach(tr => {
            tr.addEventListener('click', (e) => {
                if (e.target.closest('a')) return;
                const href = tr.getAttribute('data-href');
                if (href) window.location.href = href;
            });
        });
    </script>

    <!-- Pi Authentication -->
    <script>
        (function () {
            const usernameEl = document.getElementById('pi-username');
            const btnEl = document.getElementById('pi-signin-btn');

            function showAuthenticated(user) {
                if (user && user.username) {
                    usernameEl.textContent = '@' + user.username;
                    btnEl.style.display = 'none';
                }
            }

            function onIncompletePaymentFound(payment) {
                console.log('Incomplete payment:', payment);
            }

            async function signIn() {
                try {
                    const auth = await Pi.authenticate(['username'], onIncompletePaymentFound);
                    showAuthenticated(auth && auth.user);
                    return auth;
                } catch (err) {
                    console.error('Pi authenticate error:', err);
                    throw err;
                }
            }

            async function initAndAuth() {
                if (typeof Pi === 'undefined') {
                    console.warn('Pi SDK not available (not running in Pi Browser).');
                    return;
                }
                try {
                    await Promise.resolve(Pi.init({ version: '2.0', sandbox: false }));
                    await signIn();
                } catch (err) {
                    console.error('Pi init/auth error:', err);
                }
            }

            btnEl.addEventListener('click', async () => {
                try {
                    if (typeof Pi === 'undefined') {
                        alert('Pi SDK not available. Open this site in Pi Browser.');
                        return;
                    }
                    await Promise.resolve(Pi.init({ version: '2.0', sandbox: false }));
                    await signIn();
                } catch (err) {
                    alert('Pi Sign-In Failed: ' + (err && err.message ? err.message : err));
                }
            });

            if (document.readyState === 'complete') {
                initAndAuth();
            } else {
                window.addEventListener('load', initAndAuth);
            }
        })();
    </script>
</body>
</html>
