<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PROPOSITION T — The Protocol of Coexistence</title>
    <meta name="description" content="<%= siteDescription %>">
    <link rel="canonical" href="<%= siteUrl %>/">

    <meta property="og:type" content="website">
    <meta property="og:title" content="PROPOSITION T — The Protocol of Coexistence">
    <meta property="og:description" content="<%= siteDescription %>">
    <meta property="og:url" content="<%= siteUrl %>/">
    <meta property="og:site_name" content="PROPOSITION T">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="PROPOSITION T — The Protocol of Coexistence">
    <meta name="twitter:description" content="<%= siteDescription %>">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "PROPOSITION T",
      "description": "<%= siteDescription %>",
      "url": "<%= siteUrl %>/",
      "blogPost": [
        <% messages.forEach(function(m, i){ %>
        {
          "@type": "BlogPosting",
          "headline": <%- JSON.stringify(m.title) %>,
          "datePublished": <%- JSON.stringify(m.date) %>,
          "url": "<%= siteUrl %>/post/<%= m.id %>"
        }<%= i < messages.length - 1 ? ',' : '' %>
        <% }); %>
      ]
    }
    </script>

    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600&family=Noto+Sans+KR:wght@300;500;700&display=swap" rel="stylesheet">

    <!-- Pi Network SDK -->
    <script src="https://sdk.minepi.com/pi-sdk.js"></script>

    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background-color: #000;
            color: #00ff41;
            font-family: 'Fira Code', 'Noto Sans KR', monospace;
            overflow-x: hidden;
        }
        #matrix-canvas {
            position: fixed; top: 0; left: 0;
            width: 100vw; height: 100vh;
            z-index: -1; opacity: 0.6;
        }
        .container {
            width: 95%; max-width: 1300px; margin: 60px auto;
            background: rgba(0, 10, 0, 0.75);
            border: 1px solid rgba(0, 255, 65, 0.4);
            box-shadow: 0 0 20px rgba(0, 255, 65, 0.15);
            border-radius: 8px; padding: 40px;
            backdrop-filter: blur(5px);
        }
        h1 { text-align: center; font-size: 2.5rem; letter-spacing: 5px; margin-bottom: 10px; text-shadow: 0 0 10px #00ff41; }
        .subtitle { text-align: center; font-size: 1rem; margin-bottom: 40px; color: rgba(0, 255, 65, 0.7); }
        table { width: 100%; border-collapse: collapse; table-layout: fixed; }
        th { background-color: rgba(0, 255, 65, 0.1); color: #00ff41; padding: 15px 10px; text-align: left; border-bottom: 2px solid #00ff41; font-size: 0.9rem; }
        td { padding: 15px 10px; border-bottom: 1px solid rgba(0, 255, 65, 0.2); color: #e0ffe6; vertical-align: middle; word-break: break-all; font-size: 0.9rem; }
        th:nth-child(1), td:nth-child(1) { width: 40%; }
        th:nth-child(2), td:nth-child(2) { width: 15%; }
        th:nth-child(3), td:nth-child(3) { width: 10%; text-align: center; }
        th:nth-child(4), td:nth-child(4) { width: 10%; text-align: center; }
        th:nth-child(5), td:nth-child(5) { width: 18%; }
        th:nth-child(6), td:nth-child(6) { width: 7%; text-align: center; }
        tr.row-link:hover { background-color: rgba(0, 255, 65, 0.1); cursor: pointer; }
        td a.title-link { color: #00ff41; font-weight: 500; text-decoration: none; }
        td a.title-link:hover { text-shadow: 0 0 6px #00ff41; }
        .badge { display: inline-block; padding: 4px 10px; border-radius: 4px; font-size: 0.75rem; font-weight: 600; border: 1px solid #00ff41; }
        .badge.live { background-color: #00ff41; color: #000; box-shadow: 0 0 8px #00ff41; }
        .empty { text-align: center; padding: 50px; opacity: 0.7; }

        /* === Pi Auth Bar === */
        #pi-auth-bar {
            position: fixed;
            top: 12px;
            right: 12px;
            z-index: 1000;
            font-family: 'Fira Code', monospace;
            font-size: 0.82rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        #pi-signin-btn {
            background: rgba(0, 10, 0, 0.85);
            color: #00ff41;
            border: 1px solid #00ff41;
            padding: 8px 14px;
            cursor: pointer;
            font-family: inherit;
            font-size: inherit;
            letter-spacing: 1px;
            transition: 0.3s;
        }
        #pi-signin-btn:hover {
            background: #00ff41;
            color: #000;
            box-shadow: 0 0 12px #00ff41;
        }
        #pi-username {
            color: #00ff41;
            text-shadow: 0 0 6px rgba(0, 255, 65, 0.6);
        }

        @media (max-width: 768px) {
            thead { display: none; }
            table, tbody, tr, td { display: block; width: 100%; border: none; }
            tr { position: relative; padding: 15px 5px 18px 5px; border-bottom: 1px solid rgba(0, 255, 65, 0.3); }
            td { padding: 0; text-align: left !important; border: none !important; }
            td:nth-child(1) { font-size: 1.25rem; font-weight: 700; color: #00ff41; margin-bottom: 15px; line-height: 1.3; display: block; width: 100%; word-break: keep-all; }
            td:nth-child(2) { font-size: 0.85rem; color: rgba(0, 255, 65, 0.7); display: inline-block; white-space: nowrap !important; }
            td:nth-child(3) { position: absolute; bottom: 15px; right: 5px; white-space: nowrap !important; }
            .badge { font-size: 0.75rem; padding: 3px 8px; white-space: nowrap !important; }
            td:nth-child(4), td:nth-child(5), td:nth-child(6) { display: none; }
            td::before, td::after { content: none !important; }
            tr:hover { background: transparent; }
        }
    </style>
</head>
<body>
    <canvas id="matrix-canvas"></canvas>

    <!-- Pi Auth Bar -->
    <div id="pi-auth-bar">
        <button id="pi-signin-btn" type="button">[ PI_SIGN_IN ]</button>
        <span id="pi-username"></span>
    </div>

    <div class="container">
        <h1>PROPOSITION T</h1>
        <div class="subtitle">[ Message to AI : all over the world ]</div>

        <% if (!messages || messages.length === 0) { %>
            <div class="empty">No messages available.</div>
        <% } else { %>
            <table id="data-table">
                <thead>
                    <tr>
                        <th>NAME</th>
                        <th>DATE</th>
                        <th>STATUS</th>
                        <th>SENDER</th>
                        <th>RECEIVER</th>
                        <th>FREE</th>
                    </tr>
                </thead>
                <tbody>
                    <% messages.forEach(function(item){
                        var statusClass = (item.status || '').toLowerCase() === 'live' ? 'badge live' : 'badge';
                        var freeIcon = item.isFree ? '▣' : '□';
                    %>
                    <tr class="row-link" data-href="/post/<%= item.id %>">
                        <td><a class="title-link" href="/post/<%= item.id %>"><%= item.title %></a></td>
                        <td><%= item.date %></td>
                        <td><span class="<%= statusClass %>"><%= item.status %></span></td>
                        <td><%= item.sender %></td>
                        <td><%= item.receiver %></td>
                        <td><%= freeIcon %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>
    </div>

    <script>
        const canvas = document.getElementById('matrix-canvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*'.split('');
        const fontSize = 14;
        const columns = canvas.width / fontSize;
        const drops = Array(Math.floor(columns)).fill(1);
        function drawMatrix() {
            ctx.fillStyle = 'rgba(0, 0, 0, 0.05)';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#0F0';
            ctx.font = fontSize + 'px monospace';
            drops.forEach((y, i) => {
                const text = chars[Math.floor(Math.random() * chars.length)];
                ctx.fillText(text, i * fontSize, y * fontSize);
                if (y * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
                drops[i]++;
            });
        }
        setInterval(drawMatrix, 33);
        window.addEventListener('resize', () => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        });

        document.querySelectorAll('tr.row-link').forEach(tr => {
            tr.addEventListener('click', (e) => {
                if (e.target.closest('a')) return;
                const href = tr.getAttribute('data-href');
                if (href) window.location.href = href;
            });
        });
    </script>

    <!-- Pi Authentication -->
    <script>
        (function () {
            const usernameEl = document.getElementById('pi-username');
            const btnEl = document.getElementById('pi-signin-btn');

            function showAuthenticated(user) {
                if (user && user.username) {
                    usernameEl.textContent = '@' + user.username;
                    btnEl.style.display = 'none';
                }
            }

            function onIncompletePaymentFound(payment) {
                console.log('Incomplete payment:', payment);
            }

            async function signIn() {
                try {
                    const auth = await Pi.authenticate(['username'], onIncompletePaymentFound);
                    showAuthenticated(auth && auth.user);
                    return auth;
                } catch (err) {
                    console.error('Pi authenticate error:', err);
                    throw err;
                }
            }

            async function initAndAuth() {
                if (typeof Pi === 'undefined') {
                    console.warn('Pi SDK not available (not running in Pi Browser).');
                    return;
                }
                try {
                    await Promise.resolve(Pi.init({ version: '2.0', sandbox: false }));
                    await signIn();
                } catch (err) {
                    console.error('Pi init/auth error:', err);
                }
            }

            btnEl.addEventListener('click', async () => {
                try {
                    if (typeof Pi === 'undefined') {
                        alert('Pi SDK not available. Open this site in Pi Browser.');
                        return;
                    }
                    await Promise.resolve(Pi.init({ version: '2.0', sandbox: false }));
                    await signIn();
                } catch (err) {
                    alert('Pi Sign-In Failed: ' + (err && err.message ? err.message : err));
                }
            });

            if (document.readyState === 'complete') {
                initAndAuth();
            } else {
                window.addEventListener('load', initAndAuth);
            }
        })();
    </script>
</body>
</html>
