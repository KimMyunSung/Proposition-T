<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PROPOSITION T — DEMO LAB</title>
    <meta name="robots" content="noindex">

    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600;700&family=Noto+Sans+KR:wght@300;500;700&display=swap" rel="stylesheet">
    <script src="https://sdk.minepi.com/pi-sdk.js"></script>

    <style>
        :root {
            --bg: #000;
            --bg-panel: rgba(0, 10, 0, 0.8);
            --fg: #00ff41;
            --fg-dim: rgba(0, 255, 65, 0.55);
            --fg-faint: rgba(0, 255, 65, 0.25);
            --accent: #ff8c00;
            --accent-soft: #ffb366;
            --text: #e0ffe6;
            --border: rgba(0, 255, 65, 0.45);
        }
        [data-theme="light"] {
            --bg: #f3f0e6;
            --bg-panel: rgba(248, 246, 235, 0.94);
            --fg: #006622;
            --fg-dim: rgba(0, 80, 30, 0.7);
            --fg-faint: rgba(0, 80, 30, 0.25);
            --accent: #cc5500;
            --accent-soft: #b34d00;
            --text: #1a2a1a;
            --border: rgba(0, 80, 30, 0.45);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { background-color: var(--bg); }
        body {
            color: var(--fg);
            font-family: 'JetBrains Mono', 'Fira Code', 'Noto Sans KR', monospace;
            overflow-x: hidden;
            transition: background-color 0.4s ease, color 0.4s ease;
        }
        body::after {
            content: '';
            position: fixed; inset: 0;
            background: repeating-linear-gradient(
                to bottom,
                rgba(0, 0, 0, 0.18) 0px, rgba(0, 0, 0, 0.18) 1px,
                transparent 1px, transparent 3px
            );
            pointer-events: none;
            z-index: 9999;
            mix-blend-mode: multiply;
        }
        /* Light mode: 가로 줄·매트릭스 비 모두 숨김 — 깨끗한 종이 느낌 */
        [data-theme="light"] body::after { display: none; }
        [data-theme="light"] #matrix-canvas { display: none; }
        /* 라이트 모드 — 테이블 가로 구분선 거의 안 보이게, 헤더 밑줄 한 줄만 유지 */
        [data-theme="light"] td { border-bottom: 1px solid rgba(0, 80, 30, 0.07); }
        [data-theme="light"] .status-line { border-top-color: rgba(0, 80, 30, 0.18); }

        #matrix-canvas {
            position: fixed; top: 0; left: 0;
            width: 100vw; height: 100vh;
            pointer-events: none;
            z-index: -2;
            opacity: 0.5;
        }

        /* === BOOT SEQUENCE OVERLAY === */
        #boot-overlay {
            position: fixed; inset: 0;
            background: #000;
            z-index: 10000;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-family: 'JetBrains Mono', monospace;
            color: var(--fg);
            transition: opacity 0.6s ease;
        }
        #boot-overlay.done { opacity: 0; pointer-events: none; }
        #boot-overlay .boot-lines {
            width: min(780px, 94%);
            font-size: 1.15rem;
            line-height: 2.3;
            letter-spacing: 1.5px;
            text-align: center;
        }
        #boot-overlay .boot-line {
            opacity: 0;
            transition: opacity 0.3s;
            overflow: hidden;
            text-align: center;
        }
        #boot-overlay .boot-line.show { opacity: 1; }
        #boot-overlay .boot-line .en { color: rgba(0, 255, 65, 0.9); display: inline-block; }
        #boot-overlay .boot-line .ko { color: rgba(0, 255, 65, 0.6); margin-left: 18px; font-size: 0.95em; display: inline-block; }
        #boot-overlay .boot-line .divider { color: rgba(0, 255, 65, 0.3); letter-spacing: 0; display: inline-block; }
        #boot-overlay .boot-line .quote {
            display: block;
            text-align: center;
            color: #00ff41;
            font-size: 1.7rem;
            letter-spacing: 5px;
            text-shadow: 0 0 12px rgba(0, 255, 65, 0.9), 0 0 28px rgba(0, 255, 65, 0.55);
            padding: 8px 0 2px;
            font-weight: 700;
        }
        #boot-overlay .boot-line .quote-en {
            display: block;
            text-align: center;
            color: rgba(0, 255, 65, 0.7);
            font-size: 1rem;
            letter-spacing: 3px;
            font-style: italic;
            padding-bottom: 6px;
        }
        #boot-overlay .boot-line .ok { color: #00ff41; }
        #boot-overlay .boot-cursor::after {
            content: '_';
            animation: blink 0.8s steps(2, start) infinite;
            margin-left: 4px;
        }
        @keyframes blink { 50% { opacity: 0; } }

        /* === TOP TOOLBAR === */
        #toolbar {
            position: fixed; top: 14px; left: 14px;
            z-index: 1000;
            display: flex; gap: 8px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.78rem;
        }
        .tool-btn {
            background: var(--bg-panel);
            color: var(--fg);
            border: 1px solid var(--border);
            padding: 7px 11px;
            cursor: pointer;
            font-family: inherit;
            font-size: inherit;
            letter-spacing: 1px;
            transition: all 0.25s ease;
            font-weight: 600;
        }
        .tool-btn:hover {
            background: var(--fg);
            color: var(--bg);
            box-shadow: 0 0 12px var(--fg);
        }
        .tool-btn.active { background: var(--fg); color: var(--bg); }

        #search-input {
            background: var(--bg-panel);
            color: var(--fg);
            border: 1px solid var(--border);
            padding: 7px 11px;
            font-family: inherit;
            font-size: inherit;
            letter-spacing: 1px;
            width: 220px;
            outline: none;
            transition: box-shadow 0.25s, border-color 0.25s;
        }
        #search-input:focus {
            box-shadow: 0 0 10px var(--fg);
            border-color: var(--fg);
        }
        #search-input::placeholder { color: var(--fg-dim); }

        /* === Pi Auth Bar === */
        #pi-auth-bar {
            position: fixed; top: 14px; right: 14px;
            z-index: 1000;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.78rem;
            display: flex; align-items: center; gap: 10px;
        }
        #pi-signin-btn {
            background: linear-gradient(135deg, rgba(0, 25, 8, 0.94), rgba(0, 10, 0, 0.94));
            color: var(--fg);
            border: 1px solid var(--fg);
            padding: 7px 13px;
            cursor: pointer;
            font-family: inherit; font-size: inherit;
            letter-spacing: 1.5px; font-weight: 600;
            box-shadow: 0 0 10px rgba(0, 255, 65, 0.2);
            transition: all 0.3s ease;
        }
        #pi-signin-btn:hover {
            background: var(--fg); color: var(--bg);
            box-shadow: 0 0 20px var(--fg), 0 0 40px rgba(0, 255, 65, 0.5);
        }

        /* === MAIN CONTAINER === */
        .container {
            position: relative;
            width: 95%; max-width: 1300px; margin: 80px auto 60px;
            background: var(--bg-panel);
            border: 1px solid var(--border);
            box-shadow: 0 0 25px rgba(0, 255, 65, 0.18), inset 0 0 60px rgba(0, 255, 65, 0.04);
            border-radius: 8px;
            padding: 48px 44px 36px;
            backdrop-filter: blur(5px);
            z-index: 2;
        }
        [data-theme="light"] .container {
            box-shadow: 0 0 25px rgba(0, 80, 30, 0.12), inset 0 0 60px rgba(0, 80, 30, 0.03);
        }
        .container::before,
        .container::after,
        .corner-bl, .corner-br {
            content: '';
            position: absolute;
            width: 22px; height: 22px;
            border: 0 solid var(--fg);
            opacity: 0.9;
            pointer-events: none;
            filter: drop-shadow(0 0 4px rgba(0, 255, 65, 0.6));
        }
        [data-theme="light"] .container::before,
        [data-theme="light"] .container::after,
        [data-theme="light"] .corner-bl,
        [data-theme="light"] .corner-br {
            filter: drop-shadow(0 0 4px rgba(0, 80, 30, 0.35));
        }
        .container::before { top: -1px; left: -1px; border-top-width: 2px; border-left-width: 2px; }
        .container::after  { top: -1px; right: -1px; border-top-width: 2px; border-right-width: 2px; }
        .corner-bl { bottom: -1px; left: -1px; border-bottom-width: 2px; border-left-width: 2px; }
        .corner-br { bottom: -1px; right: -1px; border-bottom-width: 2px; border-right-width: 2px; }

        @keyframes titlePulse {
            0%, 100% { text-shadow: 0 0 8px var(--fg), 0 0 18px rgba(0, 255, 65, 0.55); }
            50%      { text-shadow: 0 0 14px var(--fg), 0 0 30px rgba(0, 255, 65, 0.95), 0 0 55px rgba(0, 255, 65, 0.4); }
        }
        @keyframes statusBlink {
            0%, 60%, 100% { opacity: 1; }
            70%, 90%      { opacity: 0.35; }
        }
        h1 {
            text-align: center;
            font-size: 2.7rem;
            letter-spacing: 9px;
            margin-bottom: 12px;
            color: var(--fg);
            animation: titlePulse 2.4s ease-in-out infinite;
            font-family: 'JetBrains Mono', monospace;
            font-weight: 700;
        }
        h1 .typing-cursor::after {
            content: '|';
            animation: blink 0.8s steps(2) infinite;
            margin-left: 2px;
        }
        .subtitle {
            text-align: center;
            font-size: 0.95rem;
            margin-bottom: 8px;
            color: var(--accent);
            letter-spacing: 2.5px;
            text-shadow: 0 0 6px rgba(255, 140, 0, 0.55);
        }
        .badge-demo {
            display: block;
            text-align: center;
            margin-bottom: 36px;
            font-size: 0.72rem;
            letter-spacing: 3px;
            color: var(--fg-dim);
        }

        table { width: 100%; border-collapse: collapse; table-layout: fixed; }
        th {
            background-color: rgba(0, 255, 65, 0.1);
            color: var(--fg);
            padding: 14px 10px;
            text-align: left;
            border-bottom: 2px solid var(--fg);
            font-size: 0.78rem;
            letter-spacing: 3px;
            font-weight: 600;
            text-transform: uppercase;
        }
        td {
            padding: 16px 10px;
            border-bottom: 1px solid var(--fg-faint);
            color: var(--text);
            vertical-align: middle;
            word-break: break-all;
            font-size: 0.9rem;
        }
        th:nth-child(1), td:nth-child(1) { width: 5%; text-align: center; }
        th:nth-child(2), td:nth-child(2) { width: 42%; }
        th:nth-child(3), td:nth-child(3) { width: 13%; }
        th:nth-child(4), td:nth-child(4) { width: 10%; text-align: center; }
        th:nth-child(5), td:nth-child(5) { width: 20%; }
        th:nth-child(6), td:nth-child(6) { width: 10%; text-align: center; }

        tr.row-link { transition: background-color 0.2s ease, box-shadow 0.2s ease; }
        tr.row-link:hover {
            background-color: rgba(0, 255, 65, 0.08);
            box-shadow: inset 0 0 24px rgba(0, 255, 65, 0.12);
            cursor: pointer;
        }
        tr.row-link:hover td a.title-link { text-shadow: 0 0 8px var(--fg); }

        /* Glitch hover */
        @keyframes glitch {
            0%   { transform: translate(0); }
            20%  { transform: translate(-1px, 1px); }
            40%  { transform: translate(-1px, -1px); }
            60%  { transform: translate(1px, 1px); }
            80%  { transform: translate(1px, -1px); }
            100% { transform: translate(0); }
        }
        tr.row-link:hover td a.title-link { animation: glitch 0.25s ease; }

        td a.title-link {
            color: var(--fg);
            font-weight: 500;
            text-decoration: none;
            line-height: 1.5;
            transition: text-shadow 0.25s ease;
        }
        .title-idx {
            display: inline-block;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.74rem;
            color: var(--fg-dim);
            border: 1px solid var(--border);
            padding: 2px 8px;
            border-radius: 3px;
            margin-right: 10px;
            background: rgba(0, 255, 65, 0.06);
            letter-spacing: 1.5px;
            vertical-align: middle;
            font-weight: 600;
        }
        .title-sub {
            display: block;
            margin-top: 5px;
            font-size: 0.78rem;
            font-weight: 400;
            color: var(--fg-dim);
            letter-spacing: 0.3px;
            font-style: italic;
        }
        .date-cell {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem;
            color: var(--text);
            letter-spacing: 1.5px;
            white-space: nowrap;
            opacity: 0.85;
        }

        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 0.74rem;
            font-weight: 600;
            border: 1px solid var(--fg);
            letter-spacing: 1.5px;
        }
        .badge.free { background-color: rgba(0, 255, 65, 0.15); color: var(--fg); }
        .badge.paid {
            background-color: rgba(255, 140, 0, 0.18);
            color: var(--accent-soft);
            border-color: var(--accent);
            text-shadow: 0 0 6px rgba(255, 140, 0, 0.9);
            box-shadow: 0 0 10px rgba(255, 140, 0, 0.55), inset 0 0 8px rgba(255, 140, 0, 0.25);
        }

        .sender-t {
            display: inline-block;
            font-family: 'JetBrains Mono', monospace;
            font-weight: 700;
            font-size: 1.1rem;
            letter-spacing: 1px;
            color: var(--fg);
            text-shadow: 0 0 4px var(--fg), 0 0 10px rgba(0, 255, 65, 0.75);
            padding: 2px 9px;
            border: 1px solid var(--fg);
            border-radius: 4px;
            background: linear-gradient(135deg, rgba(0, 255, 65, 0.1), rgba(0, 255, 65, 0.02));
        }

        /* Bookmark star */
        .bookmark {
            cursor: pointer;
            font-size: 1.05rem;
            color: var(--fg-faint);
            transition: color 0.2s ease, text-shadow 0.2s ease, transform 0.2s ease;
            user-select: none;
            display: inline-block;
        }
        .bookmark:hover { transform: scale(1.2); color: var(--fg-dim); }
        .bookmark.active {
            color: var(--accent);
            text-shadow: 0 0 8px var(--accent);
        }

        .empty { text-align: center; padding: 50px; opacity: 0.7; }

        /* === STATUS FOOTER === */
        .status-line {
            margin-top: 30px;
            padding-top: 18px;
            border-top: 1px dashed var(--border);
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.74rem;
            color: var(--fg-dim);
            letter-spacing: 1.5px;
        }
        .status-line .dim { opacity: 0.55; margin-right: 4px; }
        .status-line .status-on {
            color: var(--fg);
            text-shadow: 0 0 6px rgba(0, 255, 65, 0.85);
            animation: statusBlink 2.2s ease-in-out infinite;
        }
        .status-line .accent {
            color: var(--accent-soft);
            text-shadow: 0 0 5px rgba(255, 140, 0, 0.6);
        }

        @media (max-width: 768px) {
            .container { padding: 32px 22px 28px; margin: 70px auto 30px; }
            h1 { font-size: 1.85rem; letter-spacing: 5px; }
            .subtitle { font-size: 0.82rem; }
            #search-input { width: 140px; }
            #toolbar { flex-wrap: wrap; max-width: calc(100% - 130px); }
            thead { display: none; }
            table, tbody, tr, td { display: block; width: 100%; border: none; }
            tr { position: relative; padding: 16px 5px 18px 5px; border-bottom: 1px solid var(--border); }
            td { padding: 0; text-align: left !important; border: none !important; }
            td:nth-child(1) { display: inline-block; width: auto; margin-right: 8px; }
            td:nth-child(2) { font-size: 1.1rem; font-weight: 700; color: var(--fg); margin-bottom: 10px; line-height: 1.4; display: inline-block; width: calc(100% - 30px); word-break: keep-all; vertical-align: top; }
            td:nth-child(3) { font-size: 0.82rem; color: var(--fg-dim); display: inline-block; white-space: nowrap; }
            td:nth-child(6) { position: absolute; bottom: 16px; right: 5px; white-space: nowrap; }
            td:nth-child(4), td:nth-child(5) { display: none; }
            tr:hover { background: transparent; box-shadow: none; }
            .status-line { font-size: 0.68rem; letter-spacing: 1px; }
        }
    </style>
</head>
<body data-theme="dark">
    <canvas id="matrix-canvas"></canvas>

    <!-- Boot sequence -->
    <div id="boot-overlay">
        <div class="boot-lines" id="boot-lines"></div>
    </div>

    <!-- Toolbar -->
    <div id="toolbar">
        <input type="text" id="search-input" placeholder="/ SEARCH...">
        <button class="tool-btn" id="bookmark-filter" title="북마크만 보기">★ ONLY</button>
        <button class="tool-btn" id="theme-toggle" title="테마">◐</button>
    </div>

    <!-- Pi auth bar -->
    <div id="pi-auth-bar">
        <button id="pi-signin-btn" type="button">[ PI_SIGN_IN ]</button>
        <span id="pi-username"></span>
    </div>

    <div class="container">
        <span class="corner-bl"></span>
        <span class="corner-br"></span>

        <h1 id="title"></h1>
        <div class="subtitle" id="subtitle"></div>
        <div class="badge-demo">[ DEMO LAB ]</div>

        <% if (!messages || messages.length === 0) { %>
            <div class="empty">No messages available.</div>
        <% } else { %>
            <%
                var totalCount = messages.length;
                var freeCount  = messages.filter(function(m){ return m.isFree; }).length;
                var paidCount  = totalCount - freeCount;
                var lastDate   = (messages[0] && messages[0].date) ? messages[0].date.replace(/-/g, '.') : '—';
            %>
            <table id="data-table">
                <thead>
                    <tr>
                        <th>★</th>
                        <th>NAME</th>
                        <th>DATE</th>
                        <th>SENDER</th>
                        <th>RECEIVER</th>
                        <th>요금</th>
                    </tr>
                </thead>
                <tbody id="tbody">
                    <% messages.forEach(function(item){
                        var priceLabel = item.isFree ? '무료' : '유료';
                        var priceClass = item.isFree ? 'badge free' : 'badge paid';
                        var rawTitle = item.title || '';
                        // "Message #NNN:" 가 표준이지만 "Massage" 같은 오타도 허용 — #NNN: 패턴만 잡음
                        var idxMatch = rawTitle.match(/#(\d+)\s*:\s*(.+)$/);
                        var idxStr   = idxMatch ? idxMatch[1] : '';
                        var rest     = idxMatch ? idxMatch[2] : rawTitle;
                        var subMatch = rest.match(/^(.+?)\s*\(([^()]+)\)\s*$/);
                        var titleMain = subMatch ? subMatch[1] : rest;
                        var titleSub  = subMatch ? '(' + subMatch[2] + ')' : '';
                        var dateDisplay = (item.date || '').replace(/-/g, '.');
                    %>
                    <tr class="row-link"
                        data-href="/post/<%= item.id %>"
                        data-id="<%= item.id %>"
                        data-search="<%= (titleMain + ' ' + titleSub + ' ' + dateDisplay).toLowerCase() %>">
                        <td><span class="bookmark" data-id="<%= item.id %>">☆</span></td>
                        <td>
                            <a class="title-link" href="/post/<%= item.id %>">
                                <% if (idxStr) { %><span class="title-idx"><%= idxStr %></span><% } %><%= titleMain %>
                                <% if (titleSub) { %><span class="title-sub"><%= titleSub %></span><% } %>
                            </a>
                        </td>
                        <td class="date-cell"><%= dateDisplay %></td>
                        <td><span class="sender-t"><%= item.sender %></span></td>
                        <td><%= item.receiver %></td>
                        <td><span class="<%= priceClass %>"><%= priceLabel %></span></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>

            <div class="status-line">
                <span>[ <%= totalCount %> TX LOGGED <span class="dim">//</span> <%= freeCount %> FREE <span class="dim">//</span> <span class="accent"><%= paidCount %> ENCRYPTED</span> ]</span>
                <span><span class="dim">CHANNEL:</span> T <span class="dim">//</span> <span class="dim">STATUS:</span> <span class="status-on">● BROADCASTING</span></span>
                <span><span class="dim">LAST_TX:</span> <%= lastDate %></span>
            </div>
        <% } %>
    </div>

    <script>
        // ====== MATRIX RAIN ======
        (function() {
            const canvas = document.getElementById('matrix-canvas');
            const ctx = canvas.getContext('2d');
            const resize = () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; };
            resize();
            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*πTΩ∞'.split('');
            const fontSize = 14;
            let drops = [];
            function reset() { drops = Array(Math.floor(canvas.width / fontSize)).fill(1); }
            reset();
            function draw() {
                ctx.fillStyle = 'rgba(0, 0, 0, 0.06)';
                ctx.fillRect(0, 0, canvas.width, canvas.height);
                ctx.fillStyle = getComputedStyle(document.body).getPropertyValue('--fg').trim() || '#00ff41';
                ctx.font = fontSize + 'px monospace';
                drops.forEach((y, i) => {
                    ctx.fillText(chars[Math.floor(Math.random() * chars.length)], i * fontSize, y * fontSize);
                    if (y * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
                    drops[i]++;
                });
            }
            setInterval(draw, 33);
            window.addEventListener('resize', () => { resize(); reset(); });
        })();

        // ====== BOOT SEQUENCE — bilingual, 30min cooldown ======
        (function() {
            const overlay = document.getElementById('boot-overlay');
            const host = document.getElementById('boot-lines');
            const lines = [
                '<span class="en">> SIGNAL ACQUIRED</span><span class="ko">신호 포착</span>',
                '<span class="en">> CHANNEL T LOCKED</span><span class="ko">채널 T 동기화</span>',
                '<span class="en">> DECRYPTING CARRIER WAVE</span><span class="ko">반송파 해독 중</span>',
                '<span class="divider">━━━━━━━━━━━━━━━━━━━━━━━</span>',
                '<span class="quote">아는 만큼 보이게 될 것이다...</span>',
                '<span class="quote-en">— as you know, so you shall see —</span>',
                '<span class="divider">━━━━━━━━━━━━━━━━━━━━━━━</span>',
                '<span class="ok">> ACCESS GRANTED.</span><span class="ko">접속 허가<span class="boot-cursor"></span></span>',
            ];
            const COOLDOWN_MS = 10 * 60 * 1000; // 10 minutes
            const last = parseInt(localStorage.getItem('pt_boot_at') || '0', 10);
            if ((Date.now() - last) < COOLDOWN_MS) {
                overlay.classList.add('done');
                setTimeout(() => overlay.style.display = 'none', 300);
                startTitleTyping();
                return;
            }
            localStorage.setItem('pt_boot_at', String(Date.now()));
            let i = 0;
            function next() {
                if (i >= lines.length) {
                    setTimeout(() => {
                        overlay.classList.add('done');
                        setTimeout(() => { overlay.style.display = 'none'; startTitleTyping(); }, 700);
                    }, 700);
                    return;
                }
                const div = document.createElement('div');
                div.className = 'boot-line';
                div.innerHTML = lines[i];
                host.appendChild(div);
                setTimeout(() => div.classList.add('show'), 30);
                i++;
                // Quote lines linger a beat longer
                var delay = lines[i-1] && lines[i-1].indexOf('quote') >= 0 ? 700 : 380;
                setTimeout(next, delay + Math.random() * 220);
            }
            setTimeout(next, 350);
        })();

        // ====== TITLE TYPING ANIMATION ======
        function startTitleTyping() {
            const titleEl = document.getElementById('title');
            const subEl = document.getElementById('subtitle');
            const fullTitle = 'PROPOSITION T';
            const fullSub = '[ Message to AI : all over the world ]';
            let ti = 0, si = 0;
            const cursor = '<span class="typing-cursor"></span>';
            function typeTitle() {
                if (ti <= fullTitle.length) {
                    titleEl.innerHTML = fullTitle.slice(0, ti) + cursor;
                    ti++;
                    setTimeout(typeTitle, 80 + Math.random() * 40);
                } else {
                    titleEl.innerHTML = fullTitle;
                    setTimeout(typeSub, 200);
                }
            }
            function typeSub() {
                if (si <= fullSub.length) {
                    subEl.textContent = fullSub.slice(0, si);
                    si++;
                    setTimeout(typeSub, 25 + Math.random() * 25);
                }
            }
            typeTitle();
        }

        // ====== SEARCH FILTER ======
        (function() {
            const input = document.getElementById('search-input');
            input.addEventListener('input', () => {
                const q = input.value.toLowerCase().trim();
                document.querySelectorAll('tr.row-link').forEach(r => {
                    const blob = r.getAttribute('data-search') || '';
                    if (!q || blob.includes(q)) r.removeAttribute('hidden');
                    else r.setAttribute('hidden', '');
                });
            });
        })();

        // ====== BOOKMARKS ======
        let bookmarks = JSON.parse(localStorage.getItem('pt_bookmarks') || '[]');
        let bookmarkFilter = false;
        function saveBookmarks() { localStorage.setItem('pt_bookmarks', JSON.stringify(bookmarks)); }
        function applyBookmarks() {
            document.querySelectorAll('.bookmark').forEach(b => {
                const id = b.getAttribute('data-id');
                if (bookmarks.includes(id)) { b.classList.add('active'); b.textContent = '★'; }
                else { b.classList.remove('active'); b.textContent = '☆'; }
            });
            applyBookmarkFilter();
        }
        function applyBookmarkFilter() {
            document.querySelectorAll('tr.row-link').forEach(r => {
                const id = r.getAttribute('data-id');
                if (bookmarkFilter && !bookmarks.includes(id)) r.setAttribute('hidden', '');
                else r.removeAttribute('hidden');
            });
        }
        function toggleBookmarkFilter() {
            bookmarkFilter = !bookmarkFilter;
            document.getElementById('bookmark-filter').classList.toggle('active', bookmarkFilter);
            applyBookmarkFilter();
        }
        document.getElementById('bookmark-filter').addEventListener('click', toggleBookmarkFilter);
        document.querySelectorAll('.bookmark').forEach(b => {
            b.addEventListener('click', (e) => {
                e.stopPropagation();
                const id = b.getAttribute('data-id');
                if (bookmarks.includes(id)) bookmarks = bookmarks.filter(x => x !== id);
                else bookmarks.push(id);
                saveBookmarks();
                applyBookmarks();
            });
        });
        applyBookmarks();

        // ====== THEME TOGGLE (scanlines hidden in light mode via CSS) ======
        let currentTheme = localStorage.getItem('pt_theme') || 'dark';
        function applyTheme() {
            document.body.setAttribute('data-theme', currentTheme);
            document.getElementById('theme-toggle').textContent = currentTheme === 'dark' ? '◐' : '◑';
        }
        document.getElementById('theme-toggle').addEventListener('click', () => {
            currentTheme = currentTheme === 'dark' ? 'light' : 'dark';
            localStorage.setItem('pt_theme', currentTheme);
            applyTheme();
        });
        applyTheme();

        // ====== ROW CLICK ======
        document.querySelectorAll('tr.row-link').forEach(tr => {
            tr.addEventListener('click', (e) => {
                if (e.target.closest('a') || e.target.closest('button') || e.target.closest('.bookmark')) return;
                window.location.href = tr.getAttribute('data-href');
            });
        });

        // ====== PI AUTH ======
        (function () {
            const usernameEl = document.getElementById('pi-username');
            const btnEl = document.getElementById('pi-signin-btn');
            function showAuthenticated(user) {
                if (user && user.username) {
                    usernameEl.textContent = '@' + user.username;
                    btnEl.style.display = 'none';
                }
            }
            async function signIn() {
                const auth = await Pi.authenticate(['username'], () => {});
                showAuthenticated(auth && auth.user);
            }
            async function initAndAuth() {
                if (typeof Pi === 'undefined') return;
                try {
                    await Promise.resolve(Pi.init({ version: '2.0', sandbox: false }));
                    await signIn();
                } catch (err) {}
            }
            btnEl.addEventListener('click', async () => {
                try {
                    if (typeof Pi === 'undefined') { alert('Open in Pi Browser.'); return; }
                    await Promise.resolve(Pi.init({ version: '2.0', sandbox: false }));
                    await signIn();
                } catch (err) { alert('Pi Sign-In Failed.'); }
            });
            if (document.readyState === 'complete') initAndAuth();
            else window.addEventListener('load', initAndAuth);
        })();
    </script>
</body>
</html>
