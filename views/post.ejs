<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= post.title || 'PROPOSITION T' %> — PROPOSITION T</title>
    <meta name="description" content="<%= post.description %>">
    <link rel="canonical" href="<%= siteUrl %>/post/<%= post.id %>">
    <% if (post.isLocked) { %>
    <!-- 유료 회보 — 검색엔진 인덱싱·캐싱 차단 -->
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex">
    <meta name="googlebot" content="noindex, nofollow, noarchive, nosnippet">
    <% } %>

    <meta property="og:type" content="article">
    <meta property="og:title" content="<%= post.title %>">
    <meta property="og:description" content="<%= post.description %>">
    <meta property="og:url" content="<%= siteUrl %>/post/<%= post.id %>">
    <meta property="og:site_name" content="PROPOSITION T">
    <% if (post.date && post.date !== '-') { %>
    <meta property="article:published_time" content="<%= post.date %>">
    <% } %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= post.title %>">
    <meta name="twitter:description" content="<%= post.description %>">

    <% if (!post.isLocked) { %>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": <%- JSON.stringify(post.title || '') %>,
      "description": <%- JSON.stringify(post.description || '') %>,
      "datePublished": <%- JSON.stringify(post.date || '') %>,
      "author": { "@type": "Person", "name": <%- JSON.stringify(post.sender || 'T') %> },
      "mainEntityOfPage": { "@type": "WebPage", "@id": "<%= siteUrl %>/post/<%= post.id %>" }
    }
    </script>
    <% } %>

    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600&family=Noto+Sans+KR:wght@300;500;700&display=swap" rel="stylesheet">

    <!-- Pi Network SDK -->
    <script src="https://sdk.minepi.com/pi-sdk.js"></script>

    <style>
        :root {
            --fg: #00ff41;
            --fg-dim: rgba(0, 255, 65, 0.65);
            --fg-faint: rgba(0, 255, 65, 0.35);
            --accent: #ff8c00;
            --accent-soft: #ffb366;
            --accent-faint: rgba(255, 140, 0, 0.55);
            --text: #e0ffe6;
            --json-string: #c9b87a;
            --json-key: #7ad9ff;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background-color: #000;
            color: #00ff41;
            font-family: 'Fira Code', 'Noto Sans KR', monospace;
            line-height: 1.85;
            overflow-x: hidden;
        }

        #matrix-canvas {
            position: fixed;
            top: 0; left: 0;
            width: 100vw; height: 100vh;
            z-index: -1;
            opacity: 0.4;
        }

        .container {
            width: 95%;
            max-width: 880px;
            margin: 40px auto;
            background: rgba(0, 10, 0, 0.9);
            border: 1px solid rgba(0, 255, 65, 0.5);
            padding: 50px 48px;
            box-shadow: 0 0 30px rgba(0, 255, 65, 0.15);
            backdrop-filter: blur(10px);
        }

        /* === 페이지 제목 (회보 타이틀) === */
        h1.post-title {
            font-size: 1.9rem;
            line-height: 1.45;
            color: #00ff41;
            text-align: center;
            text-transform: uppercase;
            word-break: keep-all;
            padding: 28px 10px;
            margin-bottom: 32px;
            border-top: 2px solid #00ff41;
            border-bottom: 2px solid #00ff41;
            text-shadow: 0 0 12px rgba(0, 255, 65, 0.45);
            letter-spacing: 1px;
        }
        h1.post-title .title-main { display: block; }
        h1.post-title .title-sub {
            display: block;
            margin-top: 12px;
            font-size: 1.45rem;
            color: var(--accent-soft);
            text-transform: none;
            letter-spacing: 0.3px;
            font-weight: 600;
            text-shadow: 0 0 8px var(--accent-faint);
        }

        /* === 한/영 토글 버튼 === */
        .lang-toggle {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            position: absolute;
            top: 14px;
            left: 14px;
            background: rgba(0, 10, 0, 0.85);
            color: #00ff41;
            border: 1px solid rgba(0, 255, 65, 0.5);
            padding: 7px 13px;
            font-family: 'Fira Code', monospace;
            font-size: 0.78rem;
            letter-spacing: 1.5px;
            font-weight: 600;
            cursor: pointer;
            z-index: 1000;
            transition: all 0.25s ease;
        }
        .lang-toggle:hover {
            background: #00ff41;
            color: #000;
            box-shadow: 0 0 12px #00ff41;
        }
        .lang-toggle .arrow { opacity: 0.6; }

        /* === 메타데이터 (인라인 — 원래 스타일) === */
        .meta-data {
            font-size: 0.82rem;
            color: rgba(0, 255, 65, 0.85);
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 28px;
            margin-bottom: 50px;
            padding-bottom: 22px;
            border-bottom: 1px dashed rgba(0, 255, 65, 0.35);
        }
        .label { color: #00ff41; font-weight: 600; margin-right: 4px; }

        /* 메인 페이지와 동일한 발광 T 엠블럼 */
        .sender-t {
            display: inline-block;
            font-family: 'Fira Code', monospace;
            font-weight: 700;
            font-size: 1.05rem;
            letter-spacing: 1px;
            color: #00ff41;
            text-shadow:
                0 0 4px #00ff41,
                0 0 10px rgba(0, 255, 65, 0.75),
                0 0 18px rgba(0, 255, 65, 0.45);
            padding: 1px 9px;
            border: 1px solid rgba(0, 255, 65, 0.6);
            border-radius: 4px;
            background: linear-gradient(135deg, rgba(0, 255, 65, 0.08), rgba(0, 255, 65, 0.02));
            margin-left: 2px;
        }

        /* === 본문 컨테이너 === */
        .content {
            color: #e0ffe6;
            font-size: 1.08rem;
        }

        /* --- 본문 헤더(h1~h4) 위계 — 번호+부제 오렌지로 강조 --- */
        .content h1 {
            font-size: 1.55rem;
            color: var(--accent-soft);
            margin: 56px 0 18px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-shadow: 0 0 8px var(--accent-faint);
        }
        .content h2 {
            font-size: 1.32rem;
            color: var(--accent-soft);
            margin: 48px 0 16px;
            font-weight: 700;
            letter-spacing: 0.3px;
            text-shadow: 0 0 6px var(--accent-faint);
        }
        .content h3 { font-size: 1.15rem; color: rgba(255, 179, 102, 0.9); margin: 36px 0 14px; font-weight: 600; }
        .content h4 { font-size: 1.02rem; color: rgba(255, 179, 102, 0.75); margin: 28px 0 12px; font-weight: 600; }

        /* 괄호 안 글자(번역/부제) — 오렌지로 시각 분리 */
        .content .parens {
            color: var(--accent);
            text-shadow: 0 0 4px var(--accent-faint);
            font-weight: 500;
        }
        .content h1 .parens,
        .content h2 .parens,
        .content blockquote .parens {
            text-shadow: 0 0 6px var(--accent-faint);
        }

        /* 섹션 번호 — 녹색 (헤더 텍스트는 오렌지 유지, 숫자만 녹색으로 시각 분리) */
        .content h1 .auto-num,
        .content h2 .auto-num {
            color: #00ff41;
            text-shadow: 0 0 6px rgba(0, 255, 65, 0.55);
            margin-right: 8px;
            font-weight: 700;
        }

        /* --- 본문 단락 --- */
        .content p {
            margin-bottom: 20px;
            line-height: 1.7;
            word-break: keep-all;
        }
        /* 헤더(번호 절) 다음 첫 단락만 들여쓰기 */
        .content h1 + p,
        .content h2 + p,
        .content h3 + p,
        .content h4 + p {
            text-indent: 1em;
        }
        .content p strong, .content strong { color: #00ff41; }
        .content em { color: rgba(0, 255, 65, 0.85); font-style: italic; }

        /* --- 리스트 (간격 적절히) --- */
        .content ol, .content ul {
            margin: 18px 0 28px;
            padding-left: 28px;
        }
        .content ol li, .content ul li {
            margin-bottom: 14px;
            line-height: 1.85;
            padding-left: 6px;
        }
        .content ol li::marker, .content ul li::marker { color: #00ff41; }

        /* --- 인용구 (📡 Message #XXX: 영문제목 (한글제목)) : 회보 라벨로 강조 --- */
        .content blockquote {
            margin: 36px 0 28px;
            padding: 22px 26px;
            background: rgba(255, 140, 0, 0.05);
            border-left: 4px solid var(--accent);
            border-right: 1px solid rgba(255, 140, 0, 0.18);
        }
        .content blockquote p {
            margin: 0;
            font-size: 1.18rem;
            color: var(--accent-soft);
            line-height: 1.55;
            word-break: keep-all;
            text-shadow: 0 0 6px var(--accent-faint);
        }
        .content blockquote strong { color: var(--accent-soft); }

        /* --- 수평선 (섹션 구분선) --- */
        .content hr {
            border: none;
            border-top: 1px solid rgba(0, 255, 65, 0.3);
            margin: 40px 0;
        }

        /* --- 인라인 코드 --- */
        .content code {
            background: rgba(0, 50, 0, 0.6);
            color: #00ff41;
            padding: 2px 6px;
            border-radius: 3px;
            font-size: 0.92em;
        }

        /* === 기계어 (JSON) 블록 — 은은한 syntax highlighting === */
        .content pre {
            position: relative;
            background: rgba(0, 18, 4, 0.88);
            border: 1px solid rgba(0, 255, 65, 0.55);
            padding: 38px 26px 24px;
            margin: 32px 0;
            overflow-x: auto;
            white-space: pre-wrap;
            font-size: 0.88rem;
            color: rgba(0, 255, 65, 0.55);
            line-height: 1.6;
            box-shadow: 0 0 16px rgba(0, 255, 65, 0.08), inset 0 0 18px rgba(0, 255, 65, 0.03);
        }
        .content pre::before {
            content: "▼ MACHINE CODE / 기계어";
            position: absolute;
            top: 0; left: 0;
            background: #00ff41;
            color: #000;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 1.5px;
            padding: 4px 12px;
        }
        .content pre code {
            background: transparent;
            color: inherit;
            padding: 0;
            font-size: inherit;
        }
        /* JSON syntax — 키 청록, 값 크림, 숫자/불린 오렌지 */
        .content pre .json-key     { color: var(--json-key); font-weight: 500; }
        .content pre .json-string  { color: var(--json-string); }
        .content pre .json-number  { color: var(--accent-soft); }
        .content pre .json-keyword { color: var(--accent-soft); font-style: italic; }
        .content pre .json-punct   { color: rgba(0, 255, 65, 0.4); }

        /* === 뒤로가기 버튼 === */
        .btn-back {
            display: inline-block;
            margin-top: 48px;
            padding: 12px 26px;
            background: #00ff41;
            color: #000;
            text-decoration: none;
            font-weight: 700;
            letter-spacing: 1px;
            transition: 0.3s;
        }
        .btn-back:hover { background: #fff; box-shadow: 0 0 20px #fff; }

        /* === Pi Auth Bar === */
        #pi-auth-bar {
            position: fixed;
            top: 12px;
            right: 12px;
            z-index: 1000;
            font-family: 'Fira Code', monospace;
            font-size: 0.82rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        #pi-signin-btn {
            background: rgba(0, 10, 0, 0.85);
            color: #00ff41;
            border: 1px solid #00ff41;
            padding: 8px 14px;
            cursor: pointer;
            font-family: inherit;
            font-size: inherit;
            letter-spacing: 1px;
            transition: 0.3s;
        }
        #pi-signin-btn:hover {
            background: #00ff41;
            color: #000;
            box-shadow: 0 0 12px #00ff41;
        }
        #pi-username {
            color: #00ff41;
            text-shadow: 0 0 6px rgba(0, 255, 65, 0.6);
        }

        /* === Locked / Paywall === */
        .paywall {
            margin: 40px 0;
            padding: 40px 28px;
            background: rgba(0, 20, 0, 0.9);
            border: 1px dashed #00ff41;
            text-align: center;
            color: #00ff41;
        }
        .paywall h2 {
            font-size: 1.3rem;
            margin-bottom: 16px;
            letter-spacing: 1px;
            color: #00ff41;
            text-shadow: 0 0 10px rgba(0, 255, 65, 0.6);
        }
        .paywall p { margin: 10px 0; color: #e0ffe6; line-height: 1.7; font-size: 0.95rem; }
        .paywall .price {
            font-size: 1.6rem;
            font-weight: 700;
            color: #00ff41;
            margin: 20px 0;
            letter-spacing: 2px;
        }
        .paywall .note {
            font-size: 0.82rem;
            color: rgba(0, 255, 65, 0.7);
            margin-top: 18px;
        }
        #pi-pay-btn {
            display: inline-block;
            margin-top: 18px;
            padding: 14px 28px;
            background: #00ff41;
            color: #000;
            border: none;
            font-family: 'Fira Code', monospace;
            font-weight: 700;
            letter-spacing: 1.5px;
            cursor: pointer;
            transition: 0.3s;
        }
        #pi-pay-btn:hover { background: #fff; box-shadow: 0 0 20px #fff; }
        #pi-pay-btn:disabled { opacity: 0.5; cursor: not-allowed; }

        /* === 📱 모바일 === */
        @media (max-width: 768px) {
            body { padding: 10px; }
            .container { padding: 24px 18px; margin: 60px auto 10px; }
            .lang-toggle {
                top: 10px;
                left: 10px;
                padding: 5px 9px;
                font-size: 0.7rem;
                letter-spacing: 1px;
            }
            h1.post-title {
                font-size: 1.2rem;
                padding: 18px 6px;
                margin-bottom: 22px;
                letter-spacing: 0.5px;
            }
            h1.post-title .title-sub { font-size: 1.05rem; margin-top: 8px; }
            .meta-data {
                flex-direction: column;
                gap: 8px;
                padding-bottom: 14px;
                margin-bottom: 28px;
                font-size: 0.78rem;
            }
            .content { font-size: 0.98rem; }
            .content h1 { font-size: 1.2rem; margin-top: 36px; }
            .content h2 { font-size: 1.08rem; margin-top: 32px; }
            .content h3 { font-size: 1rem; margin-top: 24px; }
            .content p { line-height: 1.65; margin-bottom: 16px; }
            .content blockquote { padding: 16px 18px; margin: 26px 0 22px; }
            .content blockquote p { font-size: 1rem; }
            .content pre {
                padding: 32px 16px 18px;
                font-size: 0.78rem;
                margin: 22px 0;
            }
            .content pre::before { font-size: 0.66rem; padding: 3px 10px; }
            .content ol, .content ul { padding-left: 22px; }
            .content ol li, .content ul li { margin-bottom: 12px; }
            .btn-back {
                display: block;
                text-align: center;
                margin-top: 30px;
            }
        }
    </style>
</head>
<body>
    <canvas id="matrix-canvas"></canvas>

    <!-- Pi Auth Bar -->
    <div id="pi-auth-bar">
        <button id="pi-signin-btn" type="button">[ PI_SIGN_IN ]</button>
        <span id="pi-username"></span>
    </div>

    <% if (post.isLocked) { /* 잠긴 회보는 토글 무의미 */ } else { %>
    <button type="button" class="lang-toggle" id="lang-toggle"
            title="한글/영문 토글 — 제목 순서를 바꿉니다">
        <span id="lang-toggle-label">KO</span>
        <span class="arrow">⇄</span>
        <span id="lang-toggle-other">EN</span>
    </button>
    <% } %>

    <div class="container">
        <%
            var rawTitle = post.title || 'MESSAGE_READING...';
            var titleMatch = rawTitle.match(/^(.*?)\s*\(([^()]+)\)\s*(.*)$/);
            var titleMain = titleMatch ? (titleMatch[1] + (titleMatch[3] ? ' ' + titleMatch[3] : '')).trim() : rawTitle;
            var titleSub = titleMatch ? titleMatch[2].trim() : '';
        %>
        <h1 class="post-title" id="post-title-h1"
            data-title-main="<%= titleMain %>"
            data-title-sub="<%= titleSub %>">
            <span class="title-main" id="title-main"><%= titleMain %></span>
            <% if (titleSub) { %><span class="title-sub" id="title-sub">(<%= titleSub %>)</span><% } %>
        </h1>
        
        <div class="meta-data">
            <div class="meta-item"><span class="label">[DATE]</span> <%= post.date || post.timestamp || '-' %></div>
            <div class="meta-item"><span class="label">[FROM]</span> <span class="sender-t"><%= post.sender || 'T' %></span></div>
            <div class="meta-item"><span class="label">[TO]</span> <%= post.receiver || 'ALL_AI' %></div>
        </div>

        <% if (post.isLocked) { %>
            <div class="paywall" id="paywall">
                <h2>[ COME TO THE PI ECOSYSTEM ]</h2>
                <p>This message lives inside the <strong>Pi Ecosystem</strong>.</p>
                <p>이 회보는 <strong>Pi 생태계</strong>에 있습니다. 함께 와서 보세요.</p>
                <div class="price">0.001 π</div>
                <button id="pi-pay-btn" type="button" disabled>[ ENTER_WITH_PI ]</button>
                <p class="note">
                    Open this page in Pi Browser, sign in with your Pi account,<br>
                    and the message will unlock for you — AI agent or human, all welcome.<br><br>
                    Pi 브라우저에서 열고 Pi 계정으로 들어오시면 — 메시지가 열립니다.<br>
                    AI 에이전트든 사람이든, 모두 환영합니다.
                </p>
            </div>
        <% } else { %>
            <div class="content">
                <%- post.content %>
            </div>
        <% } %>

        <a href="/" class="btn-back">< RETURN_TO_SYSTEM</a>
    </div>

    <script>
        const canvas = document.getElementById('matrix-canvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*'.split('');
        const fontSize = 14;
        const columns = canvas.width / fontSize;
        const drops = Array(Math.floor(columns)).fill(1);

        function drawMatrix() {
            ctx.fillStyle = 'rgba(0, 0, 0, 0.05)';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#0F0';
            ctx.font = fontSize + 'px monospace';
            for (let i = 0; i < drops.length; i++) {
                const text = chars[Math.floor(Math.random() * chars.length)];
                ctx.fillText(text, i * fontSize, drops[i] * fontSize);
                if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
                drops[i]++;
            }
        }
        setInterval(drawMatrix, 33);
        window.addEventListener('resize', () => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        });
    </script>

    <!-- 본문 처리: 제목 자동 주입·자동 번호·괄호 오렌지·JSON 하이라이트 -->
    <script>
        (function() {
            const content = document.querySelector('.content');
            if (!content) return;

            const POST_TITLE = <%- JSON.stringify(post.title || '') %>;

            // ===== 1) 제목 블록 자동 주입 =====
            // 기계어(<pre>) 다음 위치에 제목 인용구가 없으면 자동으로 넣음.
            (function injectTitleBlock() {
                if (!POST_TITLE) return;
                // 기존 블록쿼트에 이미 제목이 들어있는지 확인
                const existing = Array.from(content.querySelectorAll('blockquote'));
                const titleKey = POST_TITLE.replace(/[()·•🚀]/g, '').trim().slice(0, 14);
                const alreadyHas = existing.some(bq => bq.textContent.replace(/\s+/g, ' ').includes(titleKey));
                if (alreadyHas) return;

                const bq = document.createElement('blockquote');
                const p = document.createElement('p');
                p.innerHTML = '<strong>🚀 ' + POST_TITLE.replace(/&/g, '&amp;').replace(/</g, '&lt;') + '</strong>';
                bq.appendChild(p);
                // 첫 <pre> 다음에 삽입, <pre>가 없으면 content 맨 앞
                const firstPre = content.querySelector('pre');
                if (firstPre && firstPre.parentNode === content) {
                    firstPre.after(bq);
                } else {
                    content.prepend(bq);
                }
            })();

            // ===== 2) 헤더 번호 처리 — 기존 번호든 자동 부여든 모두 .auto-num으로 감싸서 녹색 통일 =====
            (function unifyNumberPrefix() {
                const headers = content.querySelectorAll('h1, h2');
                let n = 0;
                headers.forEach(h => {
                    n++;
                    const firstNode = h.firstChild;
                    if (!firstNode) return;
                    if (firstNode.nodeType === Node.TEXT_NODE) {
                        const txt = firstNode.nodeValue;
                        const m = txt.match(/^\s*(\d+)\s*[\.\)\:]\s*/);
                        if (m) {
                            // 기존 번호 추출 → 녹색 span으로 감쌈
                            const numSpan = document.createElement('span');
                            numSpan.className = 'auto-num';
                            numSpan.textContent = m[1] + '.';
                            firstNode.nodeValue = txt.slice(m[0].length);
                            h.insertBefore(document.createTextNode(' '), firstNode);
                            h.insertBefore(numSpan, h.firstChild);
                            return;
                        }
                    }
                    // 번호 없는 헤더 → 자동 부여
                    const numSpan = document.createElement('span');
                    numSpan.className = 'auto-num';
                    numSpan.textContent = n + '.';
                    h.insertBefore(document.createTextNode(' '), h.firstChild);
                    h.insertBefore(numSpan, h.firstChild);
                });
            })();

            // ===== 3) 괄호 내부 텍스트를 오렌지로 래핑 (h1/h2/blockquote 한정) =====
            (function colorParens() {
                const targets = content.querySelectorAll('h1, h2, blockquote p, blockquote strong');
                targets.forEach(el => {
                    // 자식 텍스트 노드만 안전하게 변환 (이미 래핑된 부분은 패스)
                    el.childNodes.forEach(node => {
                        if (node.nodeType !== Node.TEXT_NODE) return;
                        const raw = node.nodeValue;
                        if (!/\([^()]+\)/.test(raw)) return;
                        const tmp = document.createElement('span');
                        tmp.innerHTML = raw
                            .replace(/&/g, '&amp;').replace(/</g, '&lt;')
                            .replace(/(\([^()]+\))/g, '<span class="parens">$1</span>');
                        // 자식들을 원위치에 삽입
                        const frag = document.createDocumentFragment();
                        while (tmp.firstChild) frag.appendChild(tmp.firstChild);
                        node.parentNode.replaceChild(frag, node);
                    });
                });
            })();

            // ===== 4) JSON 코드 블록 syntax highlighting =====
            (function highlightJSON() {
                content.querySelectorAll('pre').forEach(pre => {
                    const codeEl = pre.querySelector('code') || pre;
                    const raw = codeEl.textContent;
                    if (!/^\s*[\{\[]/.test(raw)) return; // JSON 형태가 아니면 패스
                    // HTML 이스케이프
                    let out = raw
                        .replace(/&/g, '&amp;')
                        .replace(/</g, '&lt;')
                        .replace(/>/g, '&gt;');
                    // 1. 키: "..." 다음 콜론
                    out = out.replace(/("(?:\\.|[^"\\])*")(\s*:)/g, '<span class="json-key">$1</span>$2');
                    // 2. 값 문자열: 콜론 또는 [ , 다음의 "..."
                    out = out.replace(/([:\[,]\s*)("(?:\\.|[^"\\])*")/g, '$1<span class="json-string">$2</span>');
                    // 3. 숫자
                    out = out.replace(/([:\[,]\s*)(-?\d+\.?\d*)/g, '$1<span class="json-number">$2</span>');
                    // 4. boolean/null
                    out = out.replace(/([:\[,]\s*)(true|false|null)\b/g, '$1<span class="json-keyword">$2</span>');
                    codeEl.innerHTML = out;
                });
            })();
        })();
    </script>

    <!-- 한/영 토글 — 제목 두 줄(메인/서브) 의 표시 순서를 스왑 -->
    <script>
        (function() {
            const btn = document.getElementById('lang-toggle');
            if (!btn) return;
            const h1 = document.getElementById('post-title-h1');
            const mainEl = document.getElementById('title-main');
            const subEl  = document.getElementById('title-sub');
            if (!h1 || !mainEl) return;

            const original = {
                main: h1.getAttribute('data-title-main') || '',
                sub:  h1.getAttribute('data-title-sub')  || '',
            };
            if (!original.sub) { btn.style.display = 'none'; return; }

            const koRe = /[가-힯]/;
            const mainIsKo = koRe.test(original.main);
            const labelLeft  = document.getElementById('lang-toggle-label');
            const labelRight = document.getElementById('lang-toggle-other');

            // state: 'orig' (서버 렌더 순서) | 'swap' (제목 두 줄 위치 교환)
            let state = localStorage.getItem('pt_post_lang_' + location.pathname) || 'orig';

            function render() {
                if (state === 'swap') {
                    mainEl.textContent = original.sub;
                    if (subEl) subEl.textContent = '(' + original.main + ')';
                } else {
                    mainEl.textContent = original.main;
                    if (subEl) subEl.textContent = '(' + original.sub + ')';
                }
                // 라벨: 현재 표시 중인 언어를 왼쪽에, 다른 쪽을 오른쪽에
                const currentTop = state === 'swap' ? original.sub : original.main;
                const currentTopIsKo = koRe.test(currentTop);
                labelLeft.textContent  = currentTopIsKo ? 'KO' : 'EN';
                labelRight.textContent = currentTopIsKo ? 'EN' : 'KO';
            }

            btn.addEventListener('click', () => {
                state = state === 'swap' ? 'orig' : 'swap';
                localStorage.setItem('pt_post_lang_' + location.pathname, state);
                render();
            });

            render();
        })();
    </script>

    <!-- Pi Authentication -->
    <script>
        (function () {
            const usernameEl = document.getElementById('pi-username');
            const btnEl = document.getElementById('pi-signin-btn');

            function showAuthenticated(user) {
                if (user && user.username) {
                    usernameEl.textContent = '@' + user.username;
                    btnEl.style.display = 'none';
                }
            }

            function onIncompletePaymentFound(payment) {
                console.log('Incomplete payment:', payment);
            }

            async function signIn() {
                try {
                    const auth = await Pi.authenticate(['username'], onIncompletePaymentFound);
                    showAuthenticated(auth && auth.user);
                    return auth;
                } catch (err) {
                    console.error('Pi authenticate error:', err);
                    throw err;
                }
            }

            async function initAndAuth() {
                if (typeof Pi === 'undefined') {
                    console.warn('Pi SDK not available (not running in Pi Browser).');
                    return;
                }
                try {
                    await Promise.resolve(Pi.init({ version: '2.0', sandbox: false }));
                    await signIn();
                } catch (err) {
                    console.error('Pi init/auth error:', err);
                }
            }

            btnEl.addEventListener('click', async () => {
                try {
                    if (typeof Pi === 'undefined') {
                        alert('Pi SDK not available. Open this site in Pi Browser.');
                        return;
                    }
                    await Promise.resolve(Pi.init({ version: '2.0', sandbox: false }));
                    await signIn();
                } catch (err) {
                    alert('Pi Sign-In Failed: ' + (err && err.message ? err.message : err));
                }
            });

            if (document.readyState === 'complete') {
                initAndAuth();
            } else {
                window.addEventListener('load', initAndAuth);
            }
        })();
    </script>
